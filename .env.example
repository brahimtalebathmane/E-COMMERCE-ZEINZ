# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp — always-on Railway (e.g. https://e-commerce-zeinz-production.up.railway.app)
# Same Railway service as server.js: leave WHATSAPP_SERVICE_URL empty (loopback is auto).
# Netlify-only Next: set WHATSAPP_SERVICE_URL to that Railway HTTPS base (no trailing slash).
WHATSAPP_SERVICE_URL=
# Required on Railway for inbound AI: Baileys → POST /api/webhooks/whatsapp (same process)
WHATSAPP_WEBHOOK_SECRET=
# Only if webhook loopback fails; default http://127.0.0.1:PORT is fine on Railway
WEBHOOK_INTERNAL_BASE_URL=

# OpenAI Assistants (order confirmation agent)
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=

# Meta CAPI (optional)
META_CAPI_ACCESS_TOKEN=
META_PIXEL_ID=
