# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp — always-on Railway (e.g. https://e-commerce-zeinz-production.up.railway.app)
# Same Railway service as server.js: leave WHATSAPP_SERVICE_URL empty (loopback is auto).
# Netlify-only Next: set WHATSAPP_SERVICE_URL to that Railway HTTPS base (no trailing slash).
WHATSAPP_SERVICE_URL=
# Shared secret (Railway + Netlify must match). Required for inbound AI.
WHATSAPP_WEBHOOK_SECRET=
# Railway only (Netlify storefront): forward inbound to Netlify webhook
# WHATSAPP_WEBHOOK_FORWARD_URL=https://zeina-ecomerce.netlify.app/api/webhooks/whatsapp
WHATSAPP_WEBHOOK_FORWARD_URL=
# Loopback override when Next runs on same Railway service as Baileys
WEBHOOK_INTERNAL_BASE_URL=

# OpenAI Assistants (order confirmation agent)
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=

# Meta CAPI (optional)
META_CAPI_ACCESS_TOKEN=
META_PIXEL_ID=
