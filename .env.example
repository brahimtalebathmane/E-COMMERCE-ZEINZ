# Public storefront URL (used in admin link previews, Meta CAPI, OneSignal click URLs). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://zeinee.com

# HMAC secret for post-checkout order actions (min 16 chars). Required in production.
ORDER_ACTION_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp — always-on Railway (e.g. https://e-commerce-zaine-production.up.railway.app)
# Used for the post-order confirmation template message (not AI).
# Same Railway service as server.js: leave WHATSAPP_SERVICE_URL empty (loopback is auto).
# Netlify-only Next: set WHATSAPP_SERVICE_URL to that Railway HTTPS base (no trailing slash).
WHATSAPP_SERVICE_URL=

# OpenAI Assistants — powers the Admin Command Assistant (chat in /admin).
# The same assistant id can be reused; admin tools are attached per-run in code,
# so no manual tool registration on the OpenAI dashboard is required.
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=

# Meta Conversions API — one token for all product pixels (Business Manager system user recommended)
META_CAPI_ACCESS_TOKEN=
# Required to see server (CAPI) events in Events Manager → Test Events (copy from Meta → Test Events tab)
# META_CAPI_TEST_EVENT_CODE=TEST12345
# Optional Graph API version (default v22.0 in code)
# META_CAPI_VERSION=v22.0
# Optional: only needed if products omit meta_pixel_id in admin (each landing page normally has its own)
# META_PIXEL_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# OneSignal — admin push notifications on new orders (REST API key from OneSignal dashboard)
# In OneSignal → Settings → Platforms → Web, set Site URL to https://zeinee.com
ONESIGNAL_REST_API_KEY=

# Upstash Redis — rate limiting for public order creation (recommended in production)
# When omitted, Postgres-backed counters are used instead (see migration 037).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
