# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL for WhatsApp completion links (set in Netlify UI or here)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# WhatsApp Business number (digits only, country code included), e.g. 15551234567
NEXT_PUBLIC_WHATSAPP_E164=

# All prices and Meta Pixel Purchase events use MRU (Mauritanian Ouguiya) in code — no env var.

# Optional fallback when the payment_methods table has no active rows (JSON array)
# PAYMENT_METHODS_JSON=[{"id":"b1","label":"Bank","account_number":"000","sort_order":0,"payment_logo_url":"https://example.com/logo.png"}]
